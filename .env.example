# ASR backend selection
# Runtime switching is available through:
#   GET  /v1/models
#   GET  /v1/models/current
#   POST /v1/models/current
ASR_BACKEND=nemo

# NeMo examples:
ASR_MODEL=parakeet-1.1b
# ASR_MODEL=parakeet-0.6b
# ASR_MODEL=nvidia/parakeet-tdt-1.1b

# Whisper / Transformers examples:
# ASR_BACKEND=whisper
# ASR_MODEL=medical-whisper-large-v3
# ASR_MODEL=Na0s/Medical-Whisper-Large-v3
# ASR_LANGUAGE=en
# ASR_TASK=transcribe

# faster-whisper / CTranslate2 examples:
# Requires optional package: faster-whisper
# ASR_BACKEND=faster-whisper
# ASR_MODEL=faster-whisper-large-v3
# ASR_MODEL=Systran/faster-whisper-large-v3
# ASR_LANGUAGE=en
# ASR_TASK=transcribe

# Generic Hugging Face Transformers ASR, e.g. Cohere
# ASR_BACKEND=transformers-asr
# ASR_MODEL=cohere-transcribe-03-2026
# ASR_MODEL=CohereLabs/cohere-transcribe-03-2026
# ASR_RETURN_TIMESTAMPS=0
# ASR_TRUST_REMOTE_CODE=0
# ASR_CHUNK_LENGTH_S=
# ASR_STRIDE_LENGTH_S=

# Hugging Face token for gated/private models
HF_TOKEN=

DIARIZE_URL=http://diarize_api:8001/v1/diarize
DIARIZE_EMPTY_CACHE=0
DIARIZE_TF32=0
VAD_DEVICE=cpu
VAD_SAMPLE_RATE=16000
VAD_THRESHOLD=0.30
VAD_MIN_SPEECH_MS=150
VAD_MIN_SILENCE_MS=220
VAD_MERGE_GAP_MS=200
VAD_TARGET_MIN_S=10.0
VAD_TARGET_MAX_S=20.0
VAD_HARD_MAX_S=30.0
VAD_OVERLAP_S=1.0
VAD_SPEECH_PAD_MS=250
VAD_ENERGY_GATE=1
VAD_ENERGY_DB=-35
VAD_ENERGY_FRAME_MS=100
VAD_ENERGY_MIN_ACTIVE_MS=500
VAD_ENERGY_MERGE_GAP_MS=800
VAD_ENERGY_ACTIVE_SKIP=0.85
VAD_UNIFORM_CHUNK_S=30
VAD_UNIFORM_OVERLAP_S=1.0
