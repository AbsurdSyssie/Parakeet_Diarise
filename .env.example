# ASR model selection
# Short alias:
ASR_MODEL=parakeet-1.1b

# Or direct NVIDIA/HuggingFace model name:
# ASR_MODEL=nvidia/parakeet-tdt-1.1b

# Hugging Face token for gated/private models
HF_TOKEN=

DIARIZE_URL=http://diarize_api:8001/v1/diarize
DIARIZE_EMPTY_CACHE=0
DIARIZE_TF32=0
VAD_DEVICE=cpu
VAD_SAMPLE_RATE=16000
VAD_THRESHOLD=0.30
VAD_MIN_SPEECH_MS=150
VAD_MIN_SILENCE_MS=220
VAD_MERGE_GAP_MS=200
VAD_TARGET_MIN_S=10.0
VAD_TARGET_MAX_S=20.0
VAD_HARD_MAX_S=30.0
VAD_OVERLAP_S=1.0
VAD_SPEECH_PAD_MS=250
VAD_ENERGY_GATE=1
VAD_ENERGY_DB=-35
VAD_ENERGY_FRAME_MS=100
VAD_ENERGY_MIN_ACTIVE_MS=500
VAD_ENERGY_MERGE_GAP_MS=800
VAD_ENERGY_ACTIVE_SKIP=0.85
VAD_UNIFORM_CHUNK_S=30
VAD_UNIFORM_OVERLAP_S=1.0
